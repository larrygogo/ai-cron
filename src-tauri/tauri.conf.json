{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Cron",
  "version": "0.1.0",
  "identifier": "com.ai-cron.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Cron",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBQjQyMUMxNUM2ODY5MTQKUldRVWFXaGN3U0cwbWxPQ05XZVpDUTN5c2xSaHJCUkIvZW5PeHhGaFk2OHBMTnNQZTEzZFBNekEK",
      "endpoints": [
        "https://github.com/larrygogo/ai-cron/releases/latest/download/latest.json"
      ]
    }
  }
}
